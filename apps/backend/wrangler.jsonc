{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "stack-template",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-13",
  "observability": {
    "enabled": true,
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "../website/dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/rpc/*"],
  },
}
