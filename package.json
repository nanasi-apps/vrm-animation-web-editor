{
  "name": "stack-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp run @template/website#build && vp run @template/backend#build",
    "deploy": "vp run @template/website#build && vp run @template/backend#deploy",
    "deploy:dry-run": "vp run @template/website#build && vp run @template/backend#deploy:dry-run",
    "dev": "vp run --filter ./apps/website --filter ./apps/backend --parallel dev",
    "format": "vp fmt . --check",
    "format:write": "vp fmt . --write",
    "lint": "vp lint",
    "prepare": "vp config",
    "ready": "vp run format && vp run lint && vp run typecheck && vp run test && vp run build",
    "test": "vp run @template/backend#test && vp run @template/website#test",
    "typecheck": "vp run @template/contract#typecheck && vp run @template/backend#typecheck && vp run @template/website#typecheck"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
